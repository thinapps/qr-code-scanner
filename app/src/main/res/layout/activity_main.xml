<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_bg">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible"
        app:scaleType="fillCenter" />

    <View
        android:id="@+id/viewScanGuide"
        android:layout_width="@dimen/scan_guide_size"
        android:layout_height="@dimen/scan_guide_size"
        android:layout_gravity="center"
        android:background="@drawable/scan_guide_overlay"
        android:importantForAccessibility="no"
        android:visibility="invisible" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnTorch"
        android:layout_width="@dimen/torch_button_size"
        android:layout_height="@dimen/torch_button_size"
        android:layout_gravity="top|end"
        android:layout_marginTop="@dimen/torch_button_margin"
        android:layout_marginEnd="@dimen/torch_button_margin_end"
        android:background="@drawable/torch_button_circle"
        android:backgroundTint="@color/torch_button_bg"
        android:contentDescription="@string/action_flashlight_on"
        android:minWidth="@dimen/view_min_size_none"
        android:minHeight="@dimen/view_min_size_none"
        android:padding="@dimen/torch_button_padding"
        android:scaleType="center"
        android:src="@drawable/ic_flash"
        android:tint="@color/md_text"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/layoutContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/scanner_panel_background"
        android:orientation="vertical"
        android:paddingStart="@dimen/app_gutter"
        android:paddingTop="@dimen/content_padding_top"
        android:paddingEnd="@dimen/app_gutter"
        android:paddingBottom="@dimen/content_padding_bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="@dimen/weighted_child_size"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_title"
                android:textColor="@color/md_text"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnHistory"
                android:layout_width="@dimen/header_icon_button_size"
                android:layout_height="@dimen/header_icon_button_size"
                android:adjustViewBounds="false"
                android:background="@drawable/icon_button_ripple"
                android:contentDescription="@string/action_open_history"
                android:maxWidth="@dimen/header_icon_size"
                android:maxHeight="@dimen/header_icon_size"
                android:minWidth="@dimen/view_min_size_none"
                android:minHeight="@dimen/view_min_size_none"
                android:padding="@dimen/header_icon_button_padding"
                android:scaleType="center"
                android:src="@drawable/ic_history"
                android:tint="@color/md_text_dim" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/status_top_margin"
            android:text="@string/scan_status_ready"
            android:textColor="@color/md_text_dim"
            android:textSize="@dimen/status_text_size" />

        <LinearLayout
            android:id="@+id/layoutPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/card_top_margin"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/camera_permission_message"
                android:textColor="@color/md_text_dim" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPermission"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/button_top_margin"
                android:text="@string/camera_permission_button"
                app:cornerRadius="@dimen/button_corner_radius" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/card_top_margin"
            app:cardBackgroundColor="@color/md_card"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="@dimen/card_stroke_width">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/card_padding"
                android:paddingTop="@dimen/card_padding_top"
                android:paddingEnd="@dimen/card_padding"
                android:paddingBottom="@dimen/card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="@dimen/weighted_child_size"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:letterSpacing="0.08"
                        android:text="@string/scan_result_label"
                        android:textAllCaps="true"
                        android:textColor="@color/md_text_dim"
                        android:textSize="@dimen/label_text_size"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btnClearResult"
                        android:layout_width="@dimen/result_close_button_size"
                        android:layout_height="@dimen/result_close_button_size"
                        android:adjustViewBounds="false"
                        android:background="@drawable/icon_button_ripple"
                        android:contentDescription="@string/action_clear_result"
                        android:maxWidth="@dimen/result_close_icon_size"
                        android:maxHeight="@dimen/result_close_icon_size"
                        android:minWidth="@dimen/view_min_size_none"
                        android:minHeight="@dimen/view_min_size_none"
                        android:padding="@dimen/result_close_button_padding"
                        android:scaleType="center"
                        android:src="@drawable/ic_close"
                        android:tint="@color/md_text_dim"
                        android:visibility="invisible" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/result_top_margin"
                    android:fontFamily="monospace"
                    android:minHeight="@dimen/result_min_height"
                    android:text="@string/scan_result_empty"
                    android:textColor="@color/md_text"
                    android:textIsSelectable="true"
                    android:textSize="@dimen/result_text_size"
                    android:typeface="monospace" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/action_row_top_margin"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopy"
                        android:layout_width="@dimen/weighted_child_size"
                        android:layout_height="@dimen/button_height"
                        android:layout_weight="1"
                        android:text="@string/action_copy"
                        app:cornerRadius="@dimen/button_corner_radius" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpen"
                        android:layout_width="@dimen/weighted_child_size"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginStart="@dimen/action_button_gap"
                        android:layout_weight="1"
                        android:text="@string/action_open"
                        app:cornerRadius="@dimen/button_corner_radius" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShare"
                        android:layout_width="@dimen/weighted_child_size"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginStart="@dimen/action_button_gap"
                        android:layout_weight="1"
                        android:text="@string/action_share"
                        app:cornerRadius="@dimen/button_corner_radius" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/footer_top_margin"
            android:gravity="center"
            android:lineSpacingExtra="@dimen/footer_line_spacing_extra"
            android:text="@string/home_footer_message"
            android:textColor="@color/md_text_dim"
            android:textSize="@dimen/footer_text_size" />
    </LinearLayout>

</FrameLayout>
