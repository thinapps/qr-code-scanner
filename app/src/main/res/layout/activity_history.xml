<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutHistoryContent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_bg"
    android:orientation="vertical"
    android:paddingStart="@dimen/app_gutter"
    android:paddingTop="@dimen/content_padding_top"
    android:paddingEnd="@dimen/app_gutter"
    android:paddingBottom="@dimen/content_padding_bottom">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnHistoryBack"
            android:layout_width="@dimen/header_icon_button_size"
            android:layout_height="@dimen/header_icon_button_size"
            android:adjustViewBounds="false"
            android:background="@drawable/icon_button_ripple"
            android:contentDescription="@string/action_back"
            android:maxWidth="@dimen/header_icon_size"
            android:maxHeight="@dimen/header_icon_size"
            android:minWidth="@dimen/view_min_size_none"
            android:minHeight="@dimen/view_min_size_none"
            android:padding="@dimen/header_icon_button_padding"
            android:scaleType="center"
            android:src="@drawable/ic_back"
            android:tint="@color/md_text_dim" />

        <TextView
            android:id="@+id/txtHistoryTitle"
            android:layout_width="@dimen/weighted_child_size"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/history_title"
            android:textColor="@color/md_text"
            android:textSize="@dimen/title_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtHistoryHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/status_top_margin"
        android:text="@string/history_hint"
        android:textColor="@color/md_text_dim"
        android:textSize="@dimen/status_text_size" />

    <TextView
        android:id="@+id/txtHistoryEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/history_empty_top_margin"
        android:gravity="center"
        android:text="@string/history_empty"
        android:textColor="@color/md_text_dim"
        android:textSize="@dimen/status_text_size" />

    <ScrollView
        android:id="@+id/scrollHistory"
        android:layout_width="match_parent"
        android:layout_height="@dimen/weighted_child_size"
        android:layout_marginTop="@dimen/card_top_margin"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/layoutHistoryList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClearHistory"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/button_top_margin"
        android:text="@string/action_clear_history"
        app:cornerRadius="@dimen/button_corner_radius" />

</LinearLayout>
